// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Fase 0 — Usuarios, roles y auditoría
// ---------------------------------------------------------------------------

/// Roles del sistema. La capa de permisos (lib/permissions) los interpreta.
enum Role {
  ADMIN // Administrador
  MANAGER // Gerente
  SALES // Vendedor
  ADMINISTRATION // Administración
  READ_ONLY // Solo lectura
}

/// Estado de la cuenta de usuario.
/// Un usuario nuevo válido queda PENDING hasta que un Administrador lo activa.
enum UserStatus {
  PENDING // Recién registrado, esperando activación de un Admin
  ACTIVE // Habilitado para operar
  DISABLED // Deshabilitado por un Admin
}

/// Usuario del sistema. Compatible con el adaptador de Prisma para Auth.js
/// (campos estándar) más los campos propios: role y status.
model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  role          Role? // Null hasta que un Admin le asigna rol
  status        UserStatus @default(PENDING)

  accounts  Account[]
  sessions  Session[]
  auditLogs AuditLog[] @relation("AuditLogActor")
  clients   Client[]   @relation("ClientOwner")

  opportunities Opportunity[] @relation("OpportunityOwner")
  quotes        Quote[]       @relation("QuoteOwner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

/// Cuenta de proveedor externo (Google) vinculada a un usuario. Modelo de Auth.js.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Sesión de usuario. Modelo de Auth.js (estrategia de sesión en base de datos).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Token de verificación. Modelo de Auth.js.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Fase 1 — CRM núcleo: clientes (cuentas) y contactos
// ---------------------------------------------------------------------------

/// Condición frente al IVA (Argentina).
enum IvaCondition {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTO
  EXENTO
  CONSUMIDOR_FINAL
  NO_ALCANZADO
}

/// Segmento de cliente según el negocio de RC Pisos Industriales.
enum ClientSegment {
  BODEGA
  AGROINDUSTRIA
  CONSTRUCTORA
  FABRICA
  LOGISTICA
  COMERCIO
  OTRO
}

/// Cliente / cuenta (empresa). Pertenece a la cartera de un vendedor (owner);
/// si ownerId es null, está en la cartera general sin asignar. La visibilidad
/// se resuelve en lib/permissions (vendedor: solo los suyos; gerente/admin: todos).
model Client {
  id           String        @id @default(cuid())
  legalName    String // Razón social
  tradeName    String? // Nombre de fantasía
  taxId        String?       @unique // CUIT
  ivaCondition IvaCondition?
  email        String?
  phone        String?
  address      String?
  city         String?
  province     String?
  industry     String? // Rubro (texto libre)
  segment      ClientSegment? // Segmento (bodega, constructora, fábrica…)
  notes        String?

  ownerId String?
  owner   User?   @relation("ClientOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contacts        Contact[]
  opportunities   Opportunity[]
  quotes          Quote[]
  ledgerMovements LedgerMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([legalName])
}

/// Persona de contacto dentro de un cliente.
model Contact {
  id        String  @id @default(cuid())
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  position  String? // Cargo
  email     String?
  phone     String?
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ---------------------------------------------------------------------------
// Fase 1 — Pipeline de oportunidades
// ---------------------------------------------------------------------------

enum Currency {
  ARS
  USD
}

/// Etapa del pipeline (columna del tablero). Configurable: nombre, color y orden.
model Stage {
  id       String @id @default(cuid())
  name     String
  color    String @default("gray")
  position Int

  opportunities Opportunity[]

  createdAt DateTime @default(now())

  @@index([position])
}

/// Oportunidad comercial. Pertenece a la cartera de un vendedor (owner) y a una
/// etapa. El dinero se modela como (amount: Decimal, currency) — nunca float.
model Opportunity {
  id       String @id @default(cuid())
  title    String
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  ownerId String?
  owner   User?   @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  stageId String
  stage   Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)

  amount   Decimal? @db.Decimal(14, 2)
  currency Currency @default(ARS)

  // Datos de obra (proyectos por m²)
  siteAddress String? // Ubicación de la obra
  estimatedM2 Decimal? @db.Decimal(12, 2) // Superficie estimada en m²

  color    String? // Etiqueta de color de la tarjeta
  isPinned Boolean @default(false)
  position Int     @default(0) // Orden dentro de la etapa
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reminders Reminder[]

  @@index([stageId])
  @@index([ownerId])
  @@index([clientId])
}

/// Recordatorio/alerta de una oportunidad, sincronizable con Google Tasks.
model Reminder {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  title         String
  dueAt         DateTime
  notes         String?
  googleTaskId  String? // Id de la tarea en Google Tasks (si se sincronizó)
  createdById   String?
  createdAt     DateTime    @default(now())

  @@index([opportunityId])
}

// ---------------------------------------------------------------------------
// Fase 2 — Presupuestos
// ---------------------------------------------------------------------------

enum QuoteStatus {
  DRAFT // Borrador
  SENT // Enviado
  APPROVED // Aprobado
  REJECTED // Rechazado
  EXPIRED // Vencido
}

enum QuoteItemType {
  PRODUCT // Producto
  SERVICE // Servicio
  TEXT // Texto libre
}

/// Alícuota de IVA configurable (p. ej. 21%, 10,5%, 27%, 0%).
model TaxRate {
  id        String   @id @default(cuid())
  name      String
  rate      Decimal  @db.Decimal(5, 2)
  isDefault Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([position])
}

/// Presupuesto. Soporta versionado (revisiones), estados e ítems. Los totales
/// se guardan como snapshot (Decimal) calculados por lib/quotes-calc.
model Quote {
  id      String  @id @default(cuid())
  code    String // Número legible, p. ej. "PRE-0001"
  version Int     @default(1) // Revisión (Rev.1, Rev.2…)
  rootId  String? // Agrupa las revisiones (id del presupuesto original)

  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ownerId  String?
  owner    User?   @relation("QuoteOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  status     QuoteStatus @default(DRAFT)
  currency   Currency    @default(ARS)
  issueDate  DateTime    @default(now())
  validUntil DateTime?
  notes      String?

  // Snapshot de totales (fuente de verdad = ítems + lib/quotes-calc).
  net      Decimal @default(0) @db.Decimal(14, 2)
  ivaTotal Decimal @default(0) @db.Decimal(14, 2)
  total    Decimal @default(0) @db.Decimal(14, 2)

  items           QuoteItem[]
  ledgerMovements LedgerMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([ownerId])
  @@index([status])
  @@index([rootId])
}

/// Ítem de un presupuesto: producto, servicio o texto libre.
model QuoteItem {
  id          String        @id @default(cuid())
  quoteId     String
  quote       Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  type        QuoteItemType @default(PRODUCT)
  description String
  quantity    Decimal       @default(1) @db.Decimal(14, 2)
  unit        String        @default("m²") // Unidad: m², un, h, ml, kg, global
  unitPrice   Decimal       @default(0) @db.Decimal(14, 2)
  ivaRate     Decimal       @default(0) @db.Decimal(5, 2)
  lineNet     Decimal       @default(0) @db.Decimal(14, 2)
  position    Int           @default(0)

  @@index([quoteId])
}

// ---------------------------------------------------------------------------
// Fase 3 — Financiero: cuenta corriente
// ---------------------------------------------------------------------------

/// Tipo de movimiento de cuenta corriente.
/// Débitos (suman deuda): factura, nota de débito.
/// Créditos (restan deuda): pago, nota de crédito.
enum LedgerMovementType {
  INVOICE // Factura
  DEBIT_NOTE // Nota de débito
  PAYMENT // Pago
  CREDIT_NOTE // Nota de crédito
}

/// Movimiento de cuenta corriente de un cliente. El saldo se DERIVA de los
/// movimientos (lib/ledger-calc) y se mantiene separado por moneda. Las altas
/// se hacen dentro de una transacción para no dejar el saldo inconsistente.
model LedgerMovement {
  id       String             @id @default(cuid())
  clientId String
  client   Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type     LedgerMovementType
  currency Currency
  amount   Decimal            @db.Decimal(14, 2)

  date        DateTime @default(now())
  description String?
  reference   String? // N° de factura/recibo, etc.

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  createdById String?
  createdAt   DateTime @default(now())

  @@index([clientId, currency])
  @@index([quoteId])
}

/// Configuración de la empresa: datos fiscales y branding (logo, colores, pie
/// de página) que definen el "diseño base" del presupuesto y su futuro PDF.
/// Fila única (id = "singleton").
model CompanySettings {
  id            String        @id @default("singleton")
  legalName     String? // Razón social
  tradeName     String? // Nombre de fantasía
  taxId         String? // CUIT
  ivaCondition  IvaCondition?
  address       String?
  city          String?
  province      String?
  postalCode    String?
  phone         String?
  email         String?
  website       String?
  logo          String? // Data URL (base64) del logo
  primaryColor  String? // Color de marca (hex) para el PDF
  quoteFooter   String? // Términos/condiciones por defecto del presupuesto
  quoteValidity Int? // Días de validez por defecto
  bankInfo      String? // Datos de pago / banco para el PDF
  updatedAt     DateTime      @updatedAt
}

/// Registro de auditoría de acciones sensibles (logins, cambios de permisos,
/// altas/bajas de usuarios, ediciones financieras).
model AuditLog {
  id         String   @id @default(cuid())
  action     String // p. ej. "user.login", "user.role_changed"
  actorId    String? // Usuario que realizó la acción (si aplica)
  targetType String? // Entidad afectada, p. ej. "User", "Quote"
  targetId   String? // Id de la entidad afectada
  metadata   Json? // Detalle adicional de la acción
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}
