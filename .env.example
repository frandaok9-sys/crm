# Copiá este archivo a ".env" y completá los valores reales.
# El archivo .env NUNCA se sube al repositorio (está en .gitignore).

# --- Base de datos (Fase 0) ---
# Cadena de conexión de PostgreSQL (Neon / Supabase / Prisma Postgres).
DATABASE_URL="postgresql://usuario:password@host:5432/basededatos?sslmode=require"

# --- Autenticación Google (Auth.js, Fase 0) ---
# Clave interna de Auth.js (generar con: npx auth secret).
AUTH_SECRET=""
# Credenciales del cliente OAuth de Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Correos que se crean como Administrador ACTIVO al ingresar por primera vez
# (separados por coma). Sirve para el primer admin del sistema.
INITIAL_ADMIN_EMAILS=""
# Dominio corporativo permitido (Google Workspace). Si se completa, cualquier
# correo de ese dominio puede entrar y queda PENDIENTE hasta ser activado.
# Dejar vacío mientras se usa Gmail común.
ALLOWED_EMAIL_DOMAIN=""

# --- Acceso de demostración (temporal) ---
# Si se define, habilita el login "prueba@gmail.com" sin Google (para mostrar
# la maqueta). Dejar vacío/sin definir para deshabilitarlo.
DEMO_PASSWORD=""

# --- IA / Anthropic (Fase 6 — asistente) ---
# Clave de la API de Anthropic (https://console.anthropic.com/settings/keys).
ANTHROPIC_API_KEY=""
# Opcional: modelo a usar. Vacío = "claude-haiku-4-5" (el más económico).
# ANTHROPIC_MODEL=""

# --- WhatsApp Cloud API (Fase 6) ---
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
